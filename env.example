# ─── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1...  # Settings → API → service_role

# ─── App URL ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000   # change to https://fatoura.pro in prod

# ─── Konnect (Tunisian payment gateway) ──────────────────────
# Dashboard: https://business.konnect.network/
KONNECT_API_KEY=your_konnect_api_key
KONNECT_WALLET_ID=your_konnect_wallet_id

# ─── TTN / ElFatoora ─────────────────────────────────────────
TTN_USERNAME=
TTN_PASSWORD=
TTN_API_URL=https://api.efactura.tn
TTN_ENV=sandbox    # sandbox | production

# ─── Fatoura Pro Seal (optional: bring-your-own certificate) ─
FATOURA_SEAL_PRIVATE_KEY=
FATOURA_SEAL_CERTIFICATE=
FATOURA_SEAL_SERIAL=
FATOURA_SEAL_EXPIRY=

# ─── Cron security ───────────────────────────────────────────
CRON_SECRET=your_random_secret_here
